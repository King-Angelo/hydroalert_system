rules_version = '2';

// Production Firestore rules. No open/temporary rules.
// Admin: Users/{uid} has user_type=='admin' and is_active==true

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getCurrentUser() {
      return get(/databases/$(database)/documents/Users/$(request.auth.uid));
    }

    function isAdmin() {
      return isAuthenticated() &&
        getCurrentUser().data.user_type == 'admin' &&
        getCurrentUser().data.is_active == true;
    }

    function isOfficial() {
      return isAuthenticated() &&
        getCurrentUser().data.user_type == 'official' &&
        getCurrentUser().data.is_active == true;
    }

    // Users: read own doc (any auth); read all if admin; write only if admin
    match /Users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isAdmin()
      );
      allow write: if isAdmin();
    }

    // Incident_Reports: create when authenticated; read if admin, official, or own report; update if admin
    match /Incident_Reports/{reportId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin() || isOfficial() ||
        (isAuthenticated() && resource.data.resident_id == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if false;  // Soft-delete via status only
    }

    // Shelters: read if authenticated; write only if admin
    match /Shelters/{shelterId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // System_Logs: read if admin; write if admin (audit logs from admin actions)
    // Backend API uses Admin SDK and bypasses rules for writes
    match /System_Logs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
