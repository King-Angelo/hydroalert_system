# Backend API (Dart Frog) — copy to a local `.env` or set equivalent keys on your host (e.g. Render).
# Never commit a file with real secrets.

# Firebase (required for Admin / Firestore / FCM)
FIREBASE_PROJECT_ID=hydroalert-dev
# Local: path to service account JSON (gitignored config/ folder is typical)
GOOGLE_APPLICATION_CREDENTIALS=
# Render: use FIREBASE_SERVICE_ACCOUNT_JSON (full JSON body) via dashboard — see backend/api/DEPLOY_RENDER.md

# CORS: production/staging admin origin (optional in dev)
# CORS_ALLOW_ORIGIN=https://your-admin.example.com

# FCM / alerts (optional; defaults exist in code)
# FCM_ALERTS_ENABLED=true
# FCM_DRY_RUN=false
# FCM_INCLUDE_ADMIN_RECIPIENTS=false
# ALERT_MIN_INTERVAL_SECONDS=120
# ALERT_DEDUPE_WINDOW_SECONDS=900

# Cron / backup (optional)
# CRON_SECRET=
# BACKUP_BUCKET=
# LOGS_RETENTION_DAYS=

# Observability (P1) — see docs/observability_p1.md
# OPS_STRUCTURED_LOGS=true
# DEPLOY_VERSION=git-sha-or-build-id
